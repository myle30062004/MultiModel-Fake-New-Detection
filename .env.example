# Environment Configuration - Copy to .env

# ============ Database ============
DATABASE_URL="postgresql://postgres:1234@localhost:5433/newsguard"

# ============ Backend ============
CHECKPOINT_PATH="./backend/models/reintel_final_model.pth"
PYTHONUNBUFFERED=1

# ============ Frontend ============
VITE_API_URL="http://localhost:8000"

# ============ Rate Limiting ============
RATE_LIMIT_REQUESTS=12
RATE_LIMIT_PERIOD=60

# ============ API Configuration ============
API_HOST="0.0.0.0"
API_PORT=8000
API_WORKERS=4

# ============ CORS ============
# For production, set to specific domains: https://example.com,https://app.example.com
CORS_ORIGINS="*"

# ============ Logging ============
LOG_LEVEL="INFO"

# ============ Optional: Cloud Storage (for production) ============
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# S3_BUCKET="newsguard-uploads"

# ============ Optional: Monitoring ============
# SENTRY_DSN=""
# DATADOG_API_KEY=""
